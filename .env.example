# Copy to .env and adjust. All have sane defaults baked into ocr_daemon.py /
# docker-compose.yml; this file is the override surface.

# --- paths (inside the container) ---
VAULT_DIR=/vault                          # mounted READ-ONLY (whole vault)
SOURCE_SUBDIR=remarkable                  # subdir of VAULT_DIR holding the source PDFs (Scrybble, rmapi, manual drop, ...)
OUT_DIR=/out                              # transcripts output base (its own volume mount)
# OUT_SUBDIR=remarkable/_transcripts      # legacy: write inside the vault if OUT_DIR is unset
OUT_SUFFIX=-handwriting_converted         # filename = <source stem><suffix>.md, e.g. Sample-handwriting_converted.md
# OUT_ALONGSIDE=0                          # 1 = write next to each source PDF (needs a WRITABLE vault; OUT_DIR ignored)
STATE_DIR=/state                          # manifest + logs (MUST be a persistent volume)

# --- model / inference (SETTLED — see the build brief before changing) ---
MODEL=gemma4:26b
OLLAMA_HOST=http://ollama:11434
THREADS=14                                # cgroup under-detection workaround on the 13600K
NO_THINK=1                                # disable thinking/reasoning trace (faster on CPU for "thinking" models)
DPI=150
MAX_PX=1568                               # the real quality/time lever (2048 ~= 2 min/page)
TIMEOUT=1800                              # per-page socket timeout (slow CPU prefill)
MODEL_WAIT_TIMEOUT=1800                   # block at startup until the model is loadable on OLLAMA_HOST (0 = disable gate)

# --- scheduling / state ---
INTERVAL=600                              # poll seconds between passes (worst-case latency floor)
INOTIFY=1                                 # 1 = wake immediately on inotify events under SOURCE_SUBDIR (Linux only; falls back to pure poll if unavailable)
HASH_CHECK=1                              # 1 = sha256 content detection (authoritative); 0 = last-modified (mtime) detection
MAX_AGE_HOURS=24                          # only consider PDFs modified within this window (0 = no limit)
MAX_RETRIES=3                             # cap retries on a genuinely broken PDF
MIN_REPROCESS_INTERVAL=0                  # min seconds between reprocesses of the SAME path (0 = off)

# Absolute paths the daemon will refuse to read or write under (defense in
# depth). Comma-separated. Default protects the standalone Scrybble container's
# auth-credential storage in case both tools run on the same host. Set to empty
# to disable the guard (not recommended).
# FORBIDDEN_PATHS=/mnt/docker/scrybble/storage

# --- tall pages: split then OCR (pick AT MOST one of AUTO_SPLIT / REQUIRE_SPLIT) ---

# Option A — AUTO_SPLIT: rm-ocr splits tall PDFs in place, then OCRs (one tool).
# Needs pypdf + numpy (+ Pillow) and a WRITABLE source dir (mount the vault :rw).
# AUTO_SPLIT=0                             # 1 = split-in-place then OCR in one pass
# SPLIT_TARGET_PAGE_HEIGHT=700             # desired output page height, px @ 72dpi
# SPLIT_MIN_GAP_HEIGHT=25                  # smallest whitespace band (px) to cut at
# SPLIT_WHITESPACE_THRESHOLD=248           # row brightness (0-255) counted as whitespace

# Option B — REQUIRE_SPLIT: wait for the standalone remarkable-pdf-splitter to run.
# Only OCR PDFs already split (carry the marker) OR that never needed splitting.
# REQUIRE_SPLIT=0                          # 1 = enable the gate (tall un-split PDFs wait as pending_split)

# Shared by both options:
# SPLIT_MAX_ASPECT=2.0                     # height/width above which a PDF is "too tall"
# SPLIT_MARKER_KEY=/RemarkableSplitter     # PDF Info-dict key the splitter stamps
# SPLIT_MARKER_VALUE=processed             # expected marker value

# --- stroke-assisted OCR context (opt-in, .rm-family sources only) ---
# STROKE_CONTEXT=0                         # 1 = parse .rm stroke geometry into a rough sketch/diagram
                                            # hint for the OCR prompt + stroke_regions_flagged in
                                            # frontmatter. Heuristic (size/shape), NOT handwriting
                                            # recognition. No-op on plain .pdf sources. Needs rmscene
                                            # (normally already present via rmc). Auto-disabled per
                                            # document if AUTO_SPLIT re-splits its rendered pages.

# --- optional politeness ---
# RUN_WINDOW=01:00-07:00                  # only process inside this local-time window (wraps midnight ok)

# --- diagnostics ---
# LOG_LEVEL=DEBUG                         # show per-file gate decisions (prefilter-skip / hash-unchanged / retry-capped / queued)
