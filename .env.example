# Copy to .env and adjust. All have sane defaults baked into ocr_daemon.py /
# docker-compose.yml; this file is the override surface.

# --- paths (inside the container) ---
VAULT_DIR=/vault                          # mounted READ-ONLY (whole vault)
SOURCE_SUBDIR=remarkable                  # subdir of VAULT_DIR holding the source PDFs (Scrybble, rmapi, manual drop, ...)
OUT_DIR=/out                              # transcripts output base (its own volume mount)
# OUT_SUBDIR=remarkable/_transcripts      # legacy: write inside the vault if OUT_DIR is unset
OUT_SUFFIX=-handwriting_converted         # filename = <source stem><suffix>.md, e.g. Carol-handwriting_converted.md
# OUT_ALONGSIDE=0                          # 1 = write next to each source PDF (needs a WRITABLE vault; OUT_DIR ignored)
STATE_DIR=/state                          # manifest + logs (MUST be a persistent volume)

# --- model / inference (SETTLED — see the build brief before changing) ---
MODEL=qwen3.5:9b
OLLAMA_HOST=http://ollama:11434
THREADS=14                                # cgroup under-detection workaround on the 13600K
NO_THINK=1                                # REQUIRED for qwen3.5: thinking ON => 27 min/page, empty output
DPI=150
MAX_PX=1568                               # the real quality/time lever (2048 ~= 2 min/page)
TIMEOUT=1800                              # per-page socket timeout (slow CPU prefill)

# --- scheduling / state ---
INTERVAL=600                              # poll seconds between passes
HASH_CHECK=1                              # 1 = sha256 content detection (authoritative); 0 = last-modified (mtime) detection
MAX_AGE_HOURS=24                          # only consider PDFs modified within this window (0 = no limit)
MAX_RETRIES=3                             # cap retries on a genuinely broken PDF
MIN_REPROCESS_INTERVAL=0                  # min seconds between reprocesses of the SAME path (0 = off)

# --- optional politeness ---
# RUN_WINDOW=01:00-07:00                  # only process inside this local-time window (wraps midnight ok)

# --- diagnostics ---
# LOG_LEVEL=DEBUG                         # show per-file gate decisions (prefilter-skip / hash-unchanged / retry-capped / queued)
